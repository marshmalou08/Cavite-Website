ame":"visitcavite","id":"58326719244"},"media_notes":{"items":[]},"like_count":0,"like_and_view_counts_disabled":false,"boosted_status":null,"boost_unavailable_identifier":null,"boost_unavailable_reason":null,"comment_count":0,"comments_disabled":null,"view_count":null,"id":"3449394362175453761_58326719244"},{"pk":"3446607178109117296","accessibility_caption":null,"caption":{"pk":"18004934309448384","text":"\ud83d\ude4c Pink Sisters' Convent and Chapel\n\nA spiritual haven.\n\nPray, feel God's presence, and you may also write your petitions. Pink Sisters is love. \n\n\u2705 Mass Schedule: \nMon - Sat: 6:30 - 7:30am\nSat: 4:20pm - 5:30 (Holy hour with mass every 1st sat)\nSun: 7:30am - 8:30am and 5:00pm - 6:00pm\n\n\u2705 ACCESSIBILITY: Accessible to private vehicles, and a 5-10 minutes walk from Emilio Aguinaldo Highway\n\n\u2705 PARKING AREA: With enough parking slots \n\n\u2705 ADDRESS: Barangay Holy Spirit drive, Tagaytay City, Cavite \n\n\u2705 Follow and like Visit Cavite\n\n\u2733\ufe0f Pictures are owned by Visit Cavite. No pictures can be used or reproduced without the approval of the owner of the Visit Cavite page.\n\n\u2733\ufe0f The indicated schedule may change depending on the establishment.\n\n#VisitCavite #Travel #Tourism #Supportlocal #Tour #Explore #ItsMoreFuninthePhilippines #Cavite #Adventure #Destination #Travel #Garden #Culture #Art #Gallery #SVDFarm #Tagaytay #Chapel #Cafe #Nature #PinkSistersConventandChapel #PinkSisters"},"audience":null,"carousel_media_count":null,"display_uri":null,"media_type":2,"carousel_media":null,"image_versions2":{"candidates":[{"height":2160,"url":"https:\/\/instagram.fceb6-4.fna.fbcdn.net\/v\/t51.71878-15\/501989182_1841207416659883_6664509246869701006_n.jpg?stp=dst-jpg_e15_tt6&_nc_cat=109&ig_cache_key=MzQ0NjYwNzE3ODEwOTExNzI5Ng\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEyMTV4MjE2MC5zZHIuQzMifQ\u00253D\u00253D&_nc_ohc=wE_40zcaeiQQ7kNvwGkHUuu&_nc_oc=AdouY0uc-XUFKD9U1TtzsL5-sTqV