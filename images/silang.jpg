<script type="application/json" data-content-len="132566" data-sjs="" data-processed="1">{"require":[["ScheduledServerJS","handle",null,[{"__bbox":{"require":[["RelayPrefetchedStreamCache","next",[],["adp_PolarisDesktopPostPageRelatedMediaGridQueryRelayPreloader_69c8c2a9dc6920438451442",{"__bbox":{"complete":true,"result":{"data":{"xdt_api__v1__profile_timeline":{"num_results":7,"items":[{"pk":"3458129840231151056","accessibility_caption":null,"caption":{"pk":"18029315921366470","text":"\ud83d\ude4c Airkin's View - Carmona Paragliding Site\n\nParagliding in Carmona.\n\nDo something different and enjoyable, try paragliding. \n\n\u2705 View's Schedule: \nMon - Sun: 5:00am - 10:00pm\n\n\u2705 Entrance and Paragliding Fee: \nPhp10.00\/head\nPhp2,000\/overnight\nPhp300.00\/Photoshoot\nPhp300.00\/Cottage\nPhp100.00\/Tent (If one wish to set up a tent)\nPhp3,500.00\/Paragliding for 15 mins.\n\n\u2705 ACCESSIBILITY: Accessible to all types of transportation. \n\n\u2705 PARKING AREA: There is an allotted parking area before the entrance of Airkin's view.\n\n\u2705 ADDRESS:  Barangay Lantic, Carmona, Cavite \n\n\u2705 Follow and like Visit Cavite\n\n\u2733\ufe0f Pictures are owned by Visit Cavite. No pictures can be used or reproduced without the approval of the owner of the Visit Cavite page.\n\n\u2733\ufe0f The indicated schedule may change depending on the establishment.\n\n#VisitCavite #Travel #Tourism #Supportlocal #Tour #Explore #ItsMoreFuninthePhilippines #Cavite #Adventure #Destination #Travel #Garden #Culture #Art #Gallery #Carmona  #Cafe #Nature #Picnic #AirkinsView #Paragliding #CarmonaParaglidingSite"},"audience":null,"carousel_media_count":null,"display_uri":null,"media_type":2,"carousel_media":null,"image_versions2":{"candidates":[{"height":607,"url":"https:\/\/instagram.fceb6-4.fna.fbcdn.net\/v\/t51.71878-15\/503029550_1665189824136854_1111664395703148907_n.jpg?stp=dst-jpg_e15_tt6&_nc_cat=109&ig_cache_key=MzQ1ODEyOTg0MDIzMTE1MTA1Ng\u00253D\u00253D.3-ccb7-5&ccb=