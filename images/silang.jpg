inationWedding #Weddings #OurLadyofLourdesParishChurch"},"audience":null,"carousel_media_count":null,"display_uri":null,"media_type":2,"carousel_media":null,"image_versions2":{"candidates":[{"height":607,"url":"https:\/\/instagram.fceb2-2.fna.fbcdn.net\/v\/t51.71878-15\/496967830_978943964453266_6034630770210455107_n.jpg?stp=dst-jpg_e15_tt6&_nc_cat=110&ig_cache_key=MzQ1Njc1NTkxMDExNjIwNDcyMg\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEwODB4NjA3LnNkci5DMyJ9&_nc_ohc=3g1xtJLat8UQ7kNvwEM-CpA&_nc_oc=Ado2gIQBZoA1JBzSgUL-zWv1H5JzHqjQ3kJ-ZHUP5F6Ky3S_qRyS0T3gdBzcr4XY23wX3kS4j3PzzcyIKhsTY9vF&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fceb2-2.fna&_nc_gid=2EWfqGpArEb83uK93KJfMw&_nc_ss=7a32e&oh=00_AfxN917bUKlDy6OdAos5xK6Rjs0LXpSBzo8SnAVv1v4BQg&oe=69CE7975","width":1080},{"height":405,"url":"https:\/\/instagram.fceb2-2.fna.fbcdn.net\/v\/t51.71878-15\/496967830_978943964453266_6034630770210455107_n.jpg?stp=dst-jpg_e35_s720x720_sh0.08_tt6&_nc_cat=110&ig_cache_key=MzQ1Njc1NTkxMDExNjIwNDcyMg\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEwODB4NjA3LnNkci5DMyJ9&_nc_ohc=3g1xtJLat8UQ7kNvwEM-CpA&_nc_oc=Ado2gIQBZoA1JBzSgUL-zWv1H5JzHqjQ3kJ-ZHUP5F6Ky3S_qRyS0T3gdBzcr4XY23wX3kS4j3PzzcyIKhsTY9vF&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fceb2-2.fna&_nc_gid=2EWfqGpArEb83uK93KJfMw&_nc_ss=7a32e&oh=00_Afy88flMydwK968Q6fQczeTFStGueB9PJ9nZQ1atwI_ZiQ&oe=69CE7975","width":720},{"height":360,"url":"https:\/\/instagram.fceb2-2.fna.fbcdn.net\/v\/t51.71878-15\/496967830_978943964453266_6034630770210455107_n.jpg?stp=dst-jpg_e35_s640x640_sh0.08_tt6&_nc_cat=110&ig_cache_key=MzQ1Njc1NTkxMDExNjIwNDcyMg\u00253D\u00253D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6InhwaWRzLjEwODB4NjA3LnNkci5DMyJ9&_nc_ohc=3g1xtJLat8UQ7kNvwEM-CpA&_nc_oc=Ado2gIQBZoA1JBzSgUL-zWv1H5JzHqjQ3kJ-ZHUP5F6Ky3S_qRyS0T3gdBzcr4XY23wX3kS4j3PzzcyIKhsTY9vF&_nc_ad=z-m&_nc_cid=0&_nc_zt=23&_nc_ht=instagram.fceb2-2.fna&_nc_gid=2EWfqGpArEb83uK93KJfMw&_nc_ss